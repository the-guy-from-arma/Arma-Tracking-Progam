generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRAINEE
  DEVELOPER
  VETERAN
  FACULTY
  ADMIN
  OWNER
}

enum ProjectStatus {
  PENDING
  ACTIVE
  PAUSED
  REJECTED
  ARCHIVED
}

enum ProjectType {
  GAMEPLAY
  TERRAIN
  VEHICLE
  FRAMEWORK
  AUDIO
  TRAINING
  OTHER
}

enum CourseLevel {
  FOUNDATION
  INTERMEDIATE
  ADVANCED
  CAPSTONE
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
}

enum SubmissionStatus {
  SUBMITTED
  PENDING_AI_REVIEW
  AI_REVIEWING
  AI_EXCEPTION
  IN_REVIEW
  REVISION_REQUIRED
  APPROVED
  DECLINED
  APPEALED
}

enum ProgramLevel {
  CERTIFICATE
  DIPLOMA
  DEGREE_PATH
  SHORT
  ASSOCIATE
  BACHELOR
}

enum AdmissionStatus {
  SUBMITTED
  UNDER_AUTOMATED_REVIEW
  CLARIFICATION_REQUIRED
  AUTOMATION_EXCEPTION
  ADMITTED
  WAITLISTED
  DECLINED
}

enum AdmissionReviewStatus {
  QUEUED
  PROCESSING
  WAITING_FOR_CONSENT
  COMPLETED
  CLARIFICATION_REQUIRED
  EXCEPTION
}

enum AdmissionDecisionOutcome {
  AUTO_ADMITTED
  CLARIFICATION_REQUIRED
  AUTOMATION_EXCEPTION
}

enum AdmissionsMode {
  OPEN
  PAUSED
}

enum EnrollmentMode {
  OPEN
  PAUSED
}

enum CampusLearningMode {
  ACTIVE
  ACADEMIC_BREAK
  MAINTENANCE
  EMERGENCY_CLOSURE
}

enum CampusSeason {
  GENERAL
  SPRING_RECESS
  SUMMER_SESSION
  WINTER_RECESS
  SEMESTER_TRANSITION
  MAINTENANCE
  EMERGENCY
}

enum OperationalPeriodStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum GrantLedgerType {
  INITIAL_AWARD
  SUPPLEMENTAL_AWARD
  TERM_AWARD
  JUST_IN_TIME_AWARD
  RENEWAL_AWARD
  COURSE_ALLOCATION
  ADJUSTMENT
  REVERSAL
  EXPIRATION
  CORRECTION
  WITHDRAWAL_REFUND
  FUNDING_REDUCTION
  STANDING_RESTORATION
}

enum FundingStandingStatus {
  GOOD
  SUPPORT
  REVIEW_REQUIRED
}

enum ProgramRequirementType {
  CORE
  SUPPORTING
  ELECTIVE
  CAPSTONE
}

enum ProgramApplicationStatus {
  SUBMITTED
  ADMITTED
  WAITLISTED
  DECLINED
  WITHDRAWN
}

enum FundingTermStatus {
  UPCOMING
  ACTIVE
  RENEWED
  COMPLETED
  PAUSED
}

enum NotificationType {
  FUNDING
  ACADEMIC
  FEEDBACK
  DEADLINE
  SYSTEM
  FACULTY
}

enum FacultyDeliveryMode {
  AUTOMATED
  ASSISTED
  HUMAN
  PAUSED
}

enum FacultyAssignmentType {
  PRIMARY_ADVISOR
  COURSE_FACULTY
}

enum FacultyMessageRole {
  STUDENT
  FACULTY
  SYSTEM
}

enum FacultyJobStatus {
  QUEUED
  WAITING_FOR_CONSENT
  PROCESSING
  COMPLETED
  EXCEPTION
  FAILED
}

enum VeteranStatus {
  NOT_DISCLOSED
  NOT_A_VETERAN
  VETERAN
  ACTIVE_DUTY
  RESERVE_OR_GUARD
  MILITARY_FAMILY
}

enum ResidencyStatus {
  NOT_DISCLOSED
  DOMESTIC
  INTERNATIONAL
  OTHER
}

enum StudentActivityType {
  ENROLLMENT
  GRADE
  ADVISING
  CREDENTIAL
  APPLICATION
  FUNDING
  PROFILE
}

enum FundingAwardType {
  INTERNAL_SCHOLARSHIP
  INTERNAL_GRANT
  UNIVERSITY_CREDIT
  PROGRAM_FUNDING
  EMPLOYER_SPONSORSHIP
  PROMOTIONAL_AWARD
  REFUND
  ADMINISTRATIVE_ADJUSTMENT
  TRANSFER_VALUE
  OTHER
}

enum FundingAwardStatus {
  PENDING
  AVAILABLE
  PARTIALLY_USED
  FULLY_USED
  EXPIRED
  SUSPENDED
  REVERSED
  REMOVED
  ADJUSTED
}

enum FundingTransactionStatus {
  PENDING
  POSTED
  REVERSED
  ADJUSTED
}

enum FundingCapability {
  VIEW
  NOTE
  ISSUE
  EDIT_DETAILS
  ADJUST
  REVERSE_UNUSED
  SUSPEND
}

enum FacultyOutreachType {
  WELCOME
  WEEKLY_PLAN
  INACTIVITY
  PROGRESS
  FEEDBACK
  PREREQUISITE
  APPLICATION
  FUNDING
  COMPLETION
}

enum FacultyEscalationStatus {
  NONE
  OPEN
  RESOLVED
}

enum AiGradeJobStatus {
  QUEUED
  WAITING_FOR_CONSENT
  PROCESSING
  COMPLETED
  EXCEPTION
  FAILED
}

enum PolicyVersionStatus {
  DRAFT
  PUBLISHED
  RETIRED
}

enum PolicyInquiryCategory {
  PRIVACY
  ELECTRONIC_RECORDS
  ACCOUNT_CLOSURE
  BOHEMIA_IP
  AI_DECISION
  MONETARY_DISCLOSURE
  ACCESSIBILITY
  TERMS_DISPUTE
  OTHER
}

enum PolicyInquiryStatus {
  OPEN
  IN_REVIEW
  AWAITING_REQUESTER
  RESOLVED
  CLOSED
}

enum PolicyMessageRole {
  REQUESTER
  OWNER
  SYSTEM
}

enum AiDataMode {
  UNCONFIRMED_OR_UNPAID
  PAID_SERVICE_CONFIRMED
  AI_DISABLED
}

enum AiDecisionStatus {
  AUTO_FINALIZED
  HUMAN_REVIEW_REQUIRED
  OVERRIDDEN
}

enum AppealStatus {
  SUBMITTED
  IN_REVIEW
  UPHELD
  OVERTURNED
  CLOSED
}

enum ObjectiveStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum ObjectivePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ProjectUpdateType {
  PROGRESS
  MILESTONE
  DECISION
  BLOCKER
}

enum SourceSyncStatus {
  CURRENT
  UPDATED
  WARNING
  FAILED
  BYPASSED
  DISABLED
}

enum GuideAudience {
  FACULTY
  ADMIN
}

enum ApplicationTrackingType {
  ADMISSION
  PROGRAM
}

enum ApplicationTrackingStatus {
  OPEN
  IN_REVIEW
  CLOSED
}

model User {
  id                        String                         @id @default(cuid())
  email                     String                         @unique
  academicEmail             String?                        @unique
  studentNumber             String?                        @unique
  isStudent                 Boolean                        @default(false)
  grantBalanceCents         Int                            @default(0)
  name                      String
  passwordHash              String
  role                      UserRole                       @default(TRAINEE)
  specialty                 String?
  suspended                 Boolean                        @default(false)
  accountClosedAt           DateTime?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  sessions                  Session[]
  projects                  Project[]                      @relation("ProjectOwner")
  reviews                   Project[]                      @relation("ProjectReviewer")
  memberships               Membership[]
  auditLogs                 AuditLog[]
  authoredCourses           Course[]                       @relation("CourseAuthor")
  courseEnrollments         CourseEnrollment[]
  courseSubmissions         CourseSubmission[]             @relation("StudentSubmissions")
  reviewedSubmissions       CourseSubmission[]             @relation("SubmissionReviewer")
  certificates              Certificate[]
  programEnrollments        ProgramEnrollment[]
  programApplications       ProgramApplication[]
  applicationTrackers       ApplicationTracking[]
  fundingTerms              StudentFundingTerm[]
  fundingStanding           StudentFundingStanding?
  notifications             Notification[]
  submissionAppeals         SubmissionAppeal[]             @relation("StudentAppeals")
  reviewedAppeals           SubmissionAppeal[]             @relation("AppealReviewer")
  studentApplication        StudentApplication?
  grantLedger               GrantLedger[]
  lessonProgress            LessonProgress[]
  quizAttempts              QuizAttempt[]
  projectUpdates            ProjectUpdate[]
  projectNotes              ProjectNote[]
  assignedObjectives        ProjectObjective[]             @relation("ObjectiveAssignee")
  projectComments           ProjectComment[]
  sourceSyncAttempts        SourceSyncAttempt[]
  sourceBypasses            CurriculumSource[]             @relation("SourceBypassOwner")
  withdrawalPolicies        WithdrawalPolicy[]
  guideProgress             GuideProgress[]
  facultyAccount            FacultyProfile?                @relation("FacultyAccount")
  facultyAssignments        FacultyAssignment[]            @relation("StudentFacultyAssignments")
  facultyMessages           FacultyMessage[]               @relation("FacultyMessageSender")
  facultyConversations      FacultyConversation[]          @relation("StudentFacultyConversations")
  supportProfile            StudentSupportProfile?
  facultyOutreach           FacultyOutreachEvent[]         @relation("StudentFacultyOutreach")
  policySignatureEvents     PolicySignatureEvent[]
  policyAcceptances         PolicyAcceptance[]
  policyInquiries           PolicyInquiry[]
  policyInquiryMessages     PolicyInquiryMessage[]         @relation("PolicyInquiryAuthor")
  profileDetails            StudentProfileDetail?
  studentActivities         StudentActivityEvent[]         @relation("StudentActivities")
  recordedActivities        StudentActivityEvent[]         @relation("ActivityActor")
  fundingAwards             FundingAward[]                 @relation("StudentFundingAwards")
  issuedFundingAwards       FundingAward[]                 @relation("FundingAwardIssuer")
  fundingAwardRevisions     FundingAwardRevision[]         @relation("FundingRevisionActor")
  fundingPermissions        FundingPermission[]            @relation("FundingPermissionUser")
  grantedFundingPermissions FundingPermission[]            @relation("FundingPermissionGrantor")
  fundingTransactions       GrantLedger[]                  @relation("FundingTransactionActor")
  admissionClarifications   AdmissionClarification[]       @relation("AdmissionClarificationApplicant")
  admissionReviewOverrides  AdmissionReviewDecision[]      @relation("AdmissionDecisionOwner")
  operationalPeriods        InstitutionOperationalPeriod[] @relation("OperationalPeriodOwner")

  @@index([role])
}

model Course {
  id                   String                     @id @default(cuid())
  code                 String                     @unique
  title                String
  summary              String
  deliverable          String
  studio               String
  level                CourseLevel
  status               CourseStatus               @default(DRAFT)
  learningCredits      Int                        @default(3)
  serviceValueCents    Int                        @default(450000)
  academy              String                     @default("Workbench Foundations")
  estimatedDays        Int                        @default(10)
  workloadHours        Int                        @default(20)
  catalogVisible       Boolean                    @default(true)
  outcomes             Json                       @default("[]")
  wikiManaged          Boolean                    @default(false)
  createdById          String?
  createdBy            User?                      @relation("CourseAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  enrollments          CourseEnrollment[]
  submissions          CourseSubmission[]
  certificates         Certificate[]
  days                 CourseDay[]
  sourceMappings       CourseSourceMapping[]
  prerequisites        CoursePrerequisite[]       @relation("CoursePrerequisites")
  requiredFor          CoursePrerequisite[]       @relation("CourseDependents")
  programRequirements  ProgramCourseRequirement[]
  termPlanCourses      TermPlanCourse[]
  gradingRubric        GradingRubric?
  facultyAssignments   FacultyAssignment[]
  facultyConversations FacultyConversation[]
  fundingTransactions  GrantLedger[]
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([status, level])
  @@index([studio])
}

model CoursePrerequisite {
  id             String @id @default(cuid())
  courseId       String
  prerequisiteId String
  course         Course @relation("CoursePrerequisites", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite   Course @relation("CourseDependents", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([courseId, prerequisiteId])
}

model CourseDay {
  id                  String           @id @default(cuid())
  courseId            String
  course              Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  dayNumber           Int
  title               String
  objectives          Json             @default("[]")
  instructionalText   String
  sourceSection       String
  workbenchSteps      Json             @default("[]")
  practicalLab        String
  completionChecklist Json             @default("[]")
  knowledgeQuestion   String
  knowledgeAnswer     String
  reflectionPrompt    String
  progress            LessonProgress[]
  attempts            QuizAttempt[]

  @@unique([courseId, dayNumber])
  @@index([courseId, dayNumber])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseDayId String
  courseDay   CourseDay @relation(fields: [courseDayId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  reflection  String?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, courseDayId])
  @@index([userId, completed])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseDayId String
  courseDay   CourseDay @relation(fields: [courseDayId], references: [id], onDelete: Cascade)
  answer      String
  correct     Boolean
  score       Int
  attemptedAt DateTime  @default(now())

  @@index([userId, courseDayId])
}

model CurriculumSource {
  id                  String                @id @default(cuid())
  wikiTitle           String                @unique
  url                 String
  revisionId          String?
  revisionTimestamp   DateTime?
  categories          Json                  @default("[]")
  statusWarnings      Json                  @default("[]")
  sourceExcerpt       String
  syncStatus          SourceSyncStatus      @default(CURRENT)
  lastSyncedAt        DateTime?
  lastAttemptAt       DateTime?
  lastSuccessAt       DateTime?
  lastHttpStatus      Int?
  lastErrorCode       String?
  lastErrorMessage    String?
  consecutiveFailures Int                   @default(0)
  lastGoodRevisionId  String?
  lastGoodExcerpt     String?
  bypassedAt          DateTime?
  bypassReason        String?
  bypassRevisionId    String?
  bypassedById        String?
  bypassedBy          User?                 @relation("SourceBypassOwner", fields: [bypassedById], references: [id], onDelete: SetNull)
  disabledAt          DateTime?
  mappings            CourseSourceMapping[]
  attempts            SourceSyncAttempt[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([syncStatus, lastAttemptAt])
}

model CourseSourceMapping {
  id        String           @id @default(cuid())
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sourceId  String
  source    CurriculumSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([courseId, sourceId])
  @@index([sourceId])
}

model SourceSyncAttempt {
  id           String           @id @default(cuid())
  sourceId     String
  source       CurriculumSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  actorId      String?
  actor        User?            @relation(fields: [actorId], references: [id], onDelete: SetNull)
  mode         String           @default("NORMAL")
  outcome      String
  httpStatus   Int?
  errorCode    String?
  errorMessage String?
  revisionId   String?
  detail       Json             @default("{}")
  startedAt    DateTime         @default(now())
  completedAt  DateTime         @default(now())

  @@index([sourceId, startedAt])
}

model StudentApplication {
  id                  String                   @id @default(cuid())
  userId              String                   @unique
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredName       String?
  country             String
  timeZone            String
  experienceLevel     String
  workbenchExperience String
  enforceExperience   String
  weeklyHours         Int
  learningGoals       String
  portfolioUrl        String?
  githubUrl           String?
  fundingStatement    String
  supportNeeds        String?
  status              AdmissionStatus          @default(ADMITTED)
  submittedAt         DateTime                 @default(now())
  reviewedAt          DateTime?
  trackingRecords     ApplicationTracking[]
  reviewJobs          AdmissionReviewJob[]
  clarifications      AdmissionClarification[]
}

model AdmissionReviewJob {
  id                 String                   @id @default(cuid())
  applicationId      String
  application        StudentApplication       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status             AdmissionReviewStatus    @default(QUEUED)
  attempt            Int                      @default(0)
  maxAttempts        Int                      @default(3)
  clarificationRound Int                      @default(0)
  stage              String                   @default("APPLICATION_RECEIVED")
  idempotencyKey     String                   @unique
  availableAt        DateTime                 @default(now())
  lockedAt           DateTime?
  heartbeatAt        DateTime?
  lastError          String?
  decision           AdmissionReviewDecision?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([status, availableAt])
  @@index([applicationId, createdAt])
}

model AdmissionReviewDecision {
  id                String                   @id @default(cuid())
  jobId             String                   @unique
  job               AdmissionReviewJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  outcome           AdmissionDecisionOutcome
  score             Int
  confidence        Float
  modelId           String
  promptVersion     String
  strengths         Json                     @default("[]")
  concerns          Json                     @default("[]")
  integrityFlags    Json                     @default("[]")
  questions         Json                     @default("[]")
  structuredResult  Json
  validationResult  Json                     @default("{}")
  ownerOverrideById String?
  ownerOverrideBy   User?                    @relation("AdmissionDecisionOwner", fields: [ownerOverrideById], references: [id], onDelete: SetNull)
  ownerOverrideNote String?
  createdAt         DateTime                 @default(now())

  @@index([outcome, createdAt])
}

model AdmissionClarification {
  id            String             @id @default(cuid())
  applicationId String
  application   StudentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicantId   String
  applicant     User               @relation("AdmissionClarificationApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  round         Int
  questions     Json
  response      Json?
  submittedAt   DateTime?
  createdAt     DateTime           @default(now())

  @@unique([applicationId, round])
  @@index([applicantId, createdAt])
}

model StudentProfileDetail {
  id                    String          @id @default(cuid())
  userId                String          @unique
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  addressLine1          String?
  addressLine2          String?
  city                  String?
  region                String?
  postalCode            String?
  country               String?
  phone                 String?
  emergencyName         String?
  emergencyRelationship String?
  emergencyPhone        String?
  veteranStatus         VeteranStatus   @default(NOT_DISCLOSED)
  residencyStatus       ResidencyStatus @default(NOT_DISCLOSED)
  preferredPronouns     String?
  minorAcademy          String?
  profilePhoto          Bytes?
  profilePhotoMime      String?
  profilePhotoUpdatedAt DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model StudentActivityEvent {
  id         String              @id @default(cuid())
  studentId  String
  student    User                @relation("StudentActivities", fields: [studentId], references: [id], onDelete: Cascade)
  type       StudentActivityType
  title      String
  detail     String
  entity     String?
  entityId   String?
  occurredAt DateTime            @default(now())
  actorId    String?
  actor      User?               @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  metadata   Json                @default("{}")
  createdAt  DateTime            @default(now())

  @@index([studentId, occurredAt])
  @@index([entity, entityId])
}

model ApplicationTracking {
  id                   String                    @id @default(cuid())
  trackingNumber       String                    @unique
  userId               String
  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                 ApplicationTrackingType
  status               ApplicationTrackingStatus @default(OPEN)
  studentApplicationId String?
  studentApplication   StudentApplication?       @relation(fields: [studentApplicationId], references: [id], onDelete: SetNull)
  programApplicationId String?
  programApplication   ProgramApplication?       @relation(fields: [programApplicationId], references: [id], onDelete: SetNull)
  outcome              String?
  statusHistory        Json                      @default("[]")
  submittedAt          DateTime                  @default(now())
  closedAt             DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([userId, status, createdAt])
  @@index([studentApplicationId])
  @@index([programApplicationId])
}

model GrantLedger {
  id                  String                   @id @default(cuid())
  userId              String
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                GrantLedgerType
  amountCents         Int
  description         String
  courseId            String?
  course              Course?                  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  fundingTermId       String?
  fundingTerm         StudentFundingTerm?      @relation(fields: [fundingTermId], references: [id], onDelete: SetNull)
  idempotencyKey      String?                  @unique
  fundingAwardId      String?
  fundingAward        FundingAward?            @relation(fields: [fundingAwardId], references: [id], onDelete: SetNull)
  status              FundingTransactionStatus @default(POSTED)
  runningBalanceCents Int?
  publicReason        String?
  internalNote        String?
  actorId             String?
  actor               User?                    @relation("FundingTransactionActor", fields: [actorId], references: [id], onDelete: SetNull)
  reversalOfId        String?
  reversalOf          GrantLedger?             @relation("FundingTransactionReversal", fields: [reversalOfId], references: [id], onDelete: SetNull)
  reversals           GrantLedger[]            @relation("FundingTransactionReversal")
  referenceNumber     String?                  @unique
  metadata            Json                     @default("{}")
  createdAt           DateTime                 @default(now())

  @@index([userId, createdAt])
  @@index([fundingAwardId, createdAt])
}

model FundingAward {
  id                   String                 @id @default(cuid())
  referenceNumber      String                 @unique
  userId               String
  user                 User                   @relation("StudentFundingAwards", fields: [userId], references: [id], onDelete: Cascade)
  type                 FundingAwardType
  status               FundingAwardStatus     @default(AVAILABLE)
  sourceName           String
  originalAmountCents  Int
  remainingAmountCents Int
  awardedAt            DateTime               @default(now())
  expiresAt            DateTime?
  publicDescription    String
  restrictions         String
  issuingDepartment    String
  issuedById           String?
  issuedBy             User?                  @relation("FundingAwardIssuer", fields: [issuedById], references: [id], onDelete: SetNull)
  internalNote         String?
  legacy               Boolean                @default(false)
  transactions         GrantLedger[]
  revisions            FundingAwardRevision[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([userId, status, awardedAt])
  @@index([expiresAt])
}

model FundingAwardRevision {
  id             String       @id @default(cuid())
  fundingAwardId String
  fundingAward   FundingAward @relation(fields: [fundingAwardId], references: [id], onDelete: Cascade)
  actorId        String?
  actor          User?        @relation("FundingRevisionActor", fields: [actorId], references: [id], onDelete: SetNull)
  action         String
  reason         String
  publicReason   String
  internalNote   String?
  previous       Json
  updated        Json
  createdAt      DateTime     @default(now())

  @@index([fundingAwardId, createdAt])
}

model FundingPermission {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation("FundingPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  capability  FundingCapability
  grantedById String
  grantedBy   User              @relation("FundingPermissionGrantor", fields: [grantedById], references: [id], onDelete: Restrict)
  createdAt   DateTime          @default(now())

  @@unique([userId, capability])
  @@index([capability])
}

model CourseEnrollment {
  id                       String            @id @default(cuid())
  courseId                 String
  course                   Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId                   String
  user                     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                   EnrollmentStatus  @default(ACTIVE)
  progress                 Int               @default(0)
  enrolledAt               DateTime          @default(now())
  expectedEndAt            DateTime?
  pausedDays               Int               @default(0)
  completedAt              DateTime?
  withdrawnAt              DateTime?
  withdrawalReason         String?
  refundCents              Int               @default(0)
  refundPercent            Int?
  withdrawalPenaltyBps     Int               @default(0)
  withdrawalPolicyId       String?
  withdrawalPolicy         WithdrawalPolicy? @relation(fields: [withdrawalPolicyId], references: [id], onDelete: SetNull)
  withdrawalPolicySnapshot Json?

  @@unique([courseId, userId])
  @@index([userId, status])
}

model WithdrawalPolicy {
  id            String             @id @default(cuid())
  name          String
  effectiveFrom DateTime           @unique
  timeTiers     Json
  progressTiers Json
  penaltyTiers  Json
  createdById   String?
  createdBy     User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  enrollments   CourseEnrollment[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([effectiveFrom])
}

model Guide {
  id        String        @id @default(cuid())
  slug      String        @unique
  audience  GuideAudience
