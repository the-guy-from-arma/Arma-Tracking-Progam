  updatedAt                  DateTime                        @updatedAt

  @@index([status, startsAt, endsAt])
}

model OperationalDeadlineAdjustment {
  id         String                       @id @default(cuid())
  periodId   String
  period     InstitutionOperationalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  previousAt DateTime
  adjustedAt DateTime
  createdAt  DateTime                     @default(now())

  @@unique([periodId, entityType, entityId])
  @@index([entityType, entityId])
}
