generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRAINEE
  DEVELOPER
  VETERAN
  ADMIN
  OWNER
}

enum ProjectStatus {
  PENDING
  ACTIVE
  PAUSED
  REJECTED
  ARCHIVED
}

enum ProjectType {
  GAMEPLAY
  TERRAIN
  VEHICLE
  FRAMEWORK
  AUDIO
  TRAINING
  OTHER
}

enum CourseLevel {
  FOUNDATION
  INTERMEDIATE
  ADVANCED
  CAPSTONE
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
}

enum SubmissionStatus {
  SUBMITTED
  IN_REVIEW
  REVISION_REQUIRED
  APPROVED
  DECLINED
}

enum ProgramLevel {
  CERTIFICATE
  DIPLOMA
  DEGREE_PATH
}

enum AdmissionStatus {
  SUBMITTED
  ADMITTED
  WAITLISTED
  DECLINED
}

enum GrantLedgerType {
  INITIAL_AWARD
  SUPPLEMENTAL_AWARD
  COURSE_ALLOCATION
  ADJUSTMENT
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  academicEmail String?     @unique
  studentNumber String?     @unique
  isStudent     Boolean     @default(false)
  grantBalanceCents Int     @default(0)
  name         String
  passwordHash String
  role         UserRole     @default(TRAINEE)
  specialty    String?
  suspended    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  sessions     Session[]
  projects     Project[]    @relation("ProjectOwner")
  reviews      Project[]    @relation("ProjectReviewer")
  memberships  Membership[]
  auditLogs    AuditLog[]
  authoredCourses       Course[]             @relation("CourseAuthor")
  courseEnrollments     CourseEnrollment[]
  courseSubmissions     CourseSubmission[]   @relation("StudentSubmissions")
  reviewedSubmissions   CourseSubmission[]   @relation("SubmissionReviewer")
  certificates          Certificate[]
  programEnrollments    ProgramEnrollment[]
  studentApplication    StudentApplication?
  grantLedger           GrantLedger[]

  @@index([role])
}

model Course {
  id              String             @id @default(cuid())
  code            String             @unique
  title           String
  summary         String
  deliverable     String
  studio          String
  level           CourseLevel
  status          CourseStatus       @default(DRAFT)
  learningCredits Int                @default(3)
  serviceValueCents Int              @default(450000)
  createdById     String?
  createdBy       User?              @relation("CourseAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  enrollments     CourseEnrollment[]
  submissions     CourseSubmission[]
  certificates    Certificate[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status, level])
  @@index([studio])
}

model StudentApplication {
  id                  String          @id @default(cuid())
  userId              String          @unique
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredName       String?
  country             String
  timeZone            String
  experienceLevel     String
  workbenchExperience String
  enforceExperience   String
  weeklyHours         Int
  learningGoals       String
  portfolioUrl        String?
  githubUrl           String?
  fundingStatement    String
  supportNeeds        String?
  status              AdmissionStatus @default(ADMITTED)
  submittedAt         DateTime        @default(now())
  reviewedAt          DateTime?
}

model GrantLedger {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        GrantLedgerType
  amountCents Int
  description String
  courseId    String?
  createdAt   DateTime        @default(now())

  @@index([userId, createdAt])
}

model CourseEnrollment {
  id          String           @id @default(cuid())
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus @default(ACTIVE)
  progress    Int              @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  @@unique([courseId, userId])
  @@index([userId, status])
}

model CourseSubmission {
  id            String           @id @default(cuid())
  courseId      String
  course        Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId     String
  student       User             @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  title         String
  summary       String
  repositoryUrl String
  demoUrl       String?
  status        SubmissionStatus @default(SUBMITTED)
  reviewerId    String?
  reviewer      User?            @relation("SubmissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  feedback      String?
  submittedAt   DateTime         @default(now())
  reviewedAt    DateTime?
  updatedAt     DateTime         @updatedAt
  certificate   Certificate?

  @@unique([courseId, studentId])
  @@index([status, submittedAt])
  @@index([studentId])
}

model Certificate {
  id              String           @id @default(cuid())
  credentialCode  String           @unique
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Restrict)
  submissionId    String           @unique
  submission      CourseSubmission @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  title           String
  issuer          String
  learningCredits Int
  issuedAt        DateTime         @default(now())

  @@index([userId, issuedAt])
}

model AcademicProgram {
  id              String              @id @default(cuid())
  code            String              @unique
  title           String
  summary         String
  level           ProgramLevel
  creditsRequired Int
  sponsoredBy     String
  active          Boolean             @default(true)
  enrollments     ProgramEnrollment[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model ProgramEnrollment {
  id          String           @id @default(cuid())
  programId   String
  program     AcademicProgram  @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus @default(ACTIVE)
  creditsEarned Int            @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  @@unique([programId, userId])
  @@index([userId, status])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  description  String
  type         ProjectType
  status       ProjectStatus @default(PENDING)
  progress     Int           @default(0)
  repository   String?
  ownerId      String
  owner        User          @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  reviewedById String?
  reviewedBy   User?         @relation("ProjectReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote   String?
  reviewedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  members      Membership[]

  @@index([status])
  @@index([ownerId])
}

model Membership {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("Contributor")
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  detail    Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}
