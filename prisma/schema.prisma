generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRAINEE
  DEVELOPER
  VETERAN
  ADMIN
  OWNER
}

enum ProjectStatus {
  PENDING
  ACTIVE
  PAUSED
  REJECTED
  ARCHIVED
}

enum ProjectType {
  GAMEPLAY
  TERRAIN
  VEHICLE
  FRAMEWORK
  AUDIO
  TRAINING
  OTHER
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  role         UserRole     @default(TRAINEE)
  specialty    String?
  suspended    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  sessions     Session[]
  projects     Project[]    @relation("ProjectOwner")
  reviews      Project[]    @relation("ProjectReviewer")
  memberships  Membership[]
  auditLogs    AuditLog[]

  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  description  String
  type         ProjectType
  status       ProjectStatus @default(PENDING)
  progress     Int           @default(0)
  repository   String?
  ownerId      String
  owner        User          @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  reviewedById String?
  reviewedBy   User?         @relation("ProjectReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote   String?
  reviewedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  members      Membership[]

  @@index([status])
  @@index([ownerId])
}

model Membership {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("Contributor")
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  detail    Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}
