generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRAINEE
  DEVELOPER
  VETERAN
  FACULTY
  ADMIN
  OWNER
}

enum ProjectStatus {
  PENDING
  ACTIVE
  PAUSED
  REJECTED
  ARCHIVED
}

enum ProjectType {
  GAMEPLAY
  TERRAIN
  VEHICLE
  FRAMEWORK
  AUDIO
  TRAINING
  OTHER
}

enum CourseLevel {
  FOUNDATION
  INTERMEDIATE
  ADVANCED
  CAPSTONE
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
}

enum SubmissionStatus {
  SUBMITTED
  PENDING_AI_REVIEW
  AI_REVIEWING
  AI_EXCEPTION
  IN_REVIEW
  REVISION_REQUIRED
  APPROVED
  DECLINED
  APPEALED
}

enum ProgramLevel {
  CERTIFICATE
  DIPLOMA
  DEGREE_PATH
  SHORT
  ASSOCIATE
  BACHELOR
}

enum AdmissionStatus {
  SUBMITTED
  ADMITTED
  WAITLISTED
  DECLINED
}

enum GrantLedgerType {
  INITIAL_AWARD
  SUPPLEMENTAL_AWARD
  TERM_AWARD
  JUST_IN_TIME_AWARD
  RENEWAL_AWARD
  COURSE_ALLOCATION
  ADJUSTMENT
  REVERSAL
  EXPIRATION
  CORRECTION
  WITHDRAWAL_REFUND
  FUNDING_REDUCTION
  STANDING_RESTORATION
}

enum FundingStandingStatus {
  GOOD
  SUPPORT
  REVIEW_REQUIRED
}

enum ProgramRequirementType {
  CORE
  SUPPORTING
  ELECTIVE
  CAPSTONE
}

enum ProgramApplicationStatus {
  SUBMITTED
  ADMITTED
  WAITLISTED
  DECLINED
  WITHDRAWN
}

enum FundingTermStatus {
  UPCOMING
  ACTIVE
  RENEWED
  COMPLETED
  PAUSED
}

enum NotificationType {
  FUNDING
  ACADEMIC
  FEEDBACK
  DEADLINE
  SYSTEM
  FACULTY
}

enum FacultyDeliveryMode {
  AUTOMATED
  ASSISTED
  HUMAN
  PAUSED
}

enum FacultyAssignmentType {
  PRIMARY_ADVISOR
  COURSE_FACULTY
}

enum FacultyMessageRole {
  STUDENT
  FACULTY
  SYSTEM
}

enum FacultyJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  EXCEPTION
  FAILED
}

enum FacultyOutreachType {
  WELCOME
  WEEKLY_PLAN
  INACTIVITY
  PROGRESS
  FEEDBACK
  PREREQUISITE
  APPLICATION
  FUNDING
  COMPLETION
}

enum FacultyEscalationStatus {
  NONE
  OPEN
  RESOLVED
}

enum AiGradeJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  EXCEPTION
  FAILED
}

enum AiDecisionStatus {
  AUTO_FINALIZED
  HUMAN_REVIEW_REQUIRED
  OVERRIDDEN
}

enum AppealStatus {
  SUBMITTED
  IN_REVIEW
  UPHELD
  OVERTURNED
  CLOSED
}

enum ObjectiveStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum ObjectivePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ProjectUpdateType {
  PROGRESS
  MILESTONE
  DECISION
  BLOCKER
}

enum SourceSyncStatus {
  CURRENT
  UPDATED
  WARNING
  FAILED
  BYPASSED
  DISABLED
}

enum GuideAudience {
  FACULTY
  ADMIN
}

enum ApplicationTrackingType {
  ADMISSION
  PROGRAM
}

enum ApplicationTrackingStatus {
  OPEN
  IN_REVIEW
  CLOSED
}

model User {
  id                  String                  @id @default(cuid())
  email               String                  @unique
  academicEmail       String?                 @unique
  studentNumber       String?                 @unique
  isStudent           Boolean                 @default(false)
  grantBalanceCents   Int                     @default(0)
  name                String
  passwordHash        String
  role                UserRole                @default(TRAINEE)
  specialty           String?
  suspended           Boolean                 @default(false)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  sessions            Session[]
  projects            Project[]               @relation("ProjectOwner")
  reviews             Project[]               @relation("ProjectReviewer")
  memberships         Membership[]
  auditLogs           AuditLog[]
  authoredCourses     Course[]                @relation("CourseAuthor")
  courseEnrollments   CourseEnrollment[]
  courseSubmissions   CourseSubmission[]      @relation("StudentSubmissions")
  reviewedSubmissions CourseSubmission[]      @relation("SubmissionReviewer")
  certificates        Certificate[]
  programEnrollments  ProgramEnrollment[]
  programApplications ProgramApplication[]
  applicationTrackers ApplicationTracking[]
  fundingTerms        StudentFundingTerm[]
  fundingStanding     StudentFundingStanding?
  notifications       Notification[]
  submissionAppeals   SubmissionAppeal[]      @relation("StudentAppeals")
  reviewedAppeals     SubmissionAppeal[]      @relation("AppealReviewer")
  studentApplication  StudentApplication?
  grantLedger         GrantLedger[]
  lessonProgress      LessonProgress[]
  quizAttempts        QuizAttempt[]
  projectUpdates      ProjectUpdate[]
  projectNotes        ProjectNote[]
  assignedObjectives  ProjectObjective[]      @relation("ObjectiveAssignee")
  projectComments     ProjectComment[]
  sourceSyncAttempts  SourceSyncAttempt[]
  sourceBypasses      CurriculumSource[]      @relation("SourceBypassOwner")
  withdrawalPolicies  WithdrawalPolicy[]
  guideProgress       GuideProgress[]
  facultyAccount      FacultyProfile?           @relation("FacultyAccount")
  facultyAssignments  FacultyAssignment[]       @relation("StudentFacultyAssignments")
  facultyMessages     FacultyMessage[]          @relation("FacultyMessageSender")
  facultyConversations FacultyConversation[]    @relation("StudentFacultyConversations")
  supportProfile      StudentSupportProfile?
  facultyOutreach     FacultyOutreachEvent[]     @relation("StudentFacultyOutreach")

  @@index([role])
}

model Course {
  id                  String                     @id @default(cuid())
  code                String                     @unique
  title               String
  summary             String
  deliverable         String
  studio              String
  level               CourseLevel
  status              CourseStatus               @default(DRAFT)
  learningCredits     Int                        @default(3)
  serviceValueCents   Int                        @default(450000)
  academy             String                     @default("Workbench Foundations")
  estimatedDays       Int                        @default(10)
  workloadHours       Int                        @default(20)
  outcomes            Json                       @default("[]")
  wikiManaged         Boolean                    @default(false)
  createdById         String?
  createdBy           User?                      @relation("CourseAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  enrollments         CourseEnrollment[]
  submissions         CourseSubmission[]
  certificates        Certificate[]
  days                CourseDay[]
  sourceMappings      CourseSourceMapping[]
  prerequisites       CoursePrerequisite[]       @relation("CoursePrerequisites")
  requiredFor         CoursePrerequisite[]       @relation("CourseDependents")
  programRequirements ProgramCourseRequirement[]
  termPlanCourses     TermPlanCourse[]
  gradingRubric       GradingRubric?
  facultyAssignments  FacultyAssignment[]
  facultyConversations FacultyConversation[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([status, level])
  @@index([studio])
}

model CoursePrerequisite {
  id             String @id @default(cuid())
  courseId       String
  prerequisiteId String
  course         Course @relation("CoursePrerequisites", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite   Course @relation("CourseDependents", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([courseId, prerequisiteId])
}

model CourseDay {
  id                  String           @id @default(cuid())
  courseId            String
  course              Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  dayNumber           Int
  title               String
  objectives          Json             @default("[]")
  instructionalText   String
  sourceSection       String
  workbenchSteps      Json             @default("[]")
  practicalLab        String
  completionChecklist Json             @default("[]")
  knowledgeQuestion   String
  knowledgeAnswer     String
  reflectionPrompt    String
  progress            LessonProgress[]
  attempts            QuizAttempt[]

  @@unique([courseId, dayNumber])
  @@index([courseId, dayNumber])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseDayId String
  courseDay   CourseDay @relation(fields: [courseDayId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  reflection  String?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, courseDayId])
  @@index([userId, completed])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseDayId String
  courseDay   CourseDay @relation(fields: [courseDayId], references: [id], onDelete: Cascade)
  answer      String
  correct     Boolean
  score       Int
  attemptedAt DateTime  @default(now())

  @@index([userId, courseDayId])
}

model CurriculumSource {
  id                  String                @id @default(cuid())
  wikiTitle           String                @unique
  url                 String
  revisionId          String?
  revisionTimestamp   DateTime?
  categories          Json                  @default("[]")
  statusWarnings      Json                  @default("[]")
  sourceExcerpt       String
  syncStatus          SourceSyncStatus      @default(CURRENT)
  lastSyncedAt        DateTime?
  lastAttemptAt       DateTime?
  lastSuccessAt       DateTime?
  lastHttpStatus      Int?
  lastErrorCode       String?
  lastErrorMessage    String?
  consecutiveFailures Int                   @default(0)
  lastGoodRevisionId  String?
  lastGoodExcerpt     String?
  bypassedAt          DateTime?
  bypassReason        String?
  bypassRevisionId    String?
  bypassedById        String?
  bypassedBy          User?                 @relation("SourceBypassOwner", fields: [bypassedById], references: [id], onDelete: SetNull)
  disabledAt          DateTime?
  mappings            CourseSourceMapping[]
  attempts            SourceSyncAttempt[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([syncStatus, lastAttemptAt])
}

model CourseSourceMapping {
  id        String           @id @default(cuid())
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sourceId  String
  source    CurriculumSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([courseId, sourceId])
  @@index([sourceId])
}

model SourceSyncAttempt {
  id           String           @id @default(cuid())
  sourceId     String
  source       CurriculumSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  actorId      String?
  actor        User?            @relation(fields: [actorId], references: [id], onDelete: SetNull)
  mode         String           @default("NORMAL")
  outcome      String
  httpStatus   Int?
  errorCode    String?
  errorMessage String?
  revisionId   String?
  detail       Json             @default("{}")
  startedAt    DateTime         @default(now())
  completedAt  DateTime         @default(now())

  @@index([sourceId, startedAt])
}

model StudentApplication {
  id                  String                @id @default(cuid())
  userId              String                @unique
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredName       String?
  country             String
  timeZone            String
  experienceLevel     String
  workbenchExperience String
  enforceExperience   String
  weeklyHours         Int
  learningGoals       String
  portfolioUrl        String?
  githubUrl           String?
  fundingStatement    String
  supportNeeds        String?
  status              AdmissionStatus       @default(ADMITTED)
  submittedAt         DateTime              @default(now())
  reviewedAt          DateTime?
  trackingRecords     ApplicationTracking[]
}

model ApplicationTracking {
  id                   String                    @id @default(cuid())
  trackingNumber       String                    @unique
  userId               String
  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                 ApplicationTrackingType
  status               ApplicationTrackingStatus @default(OPEN)
  studentApplicationId String?
  studentApplication   StudentApplication?       @relation(fields: [studentApplicationId], references: [id], onDelete: SetNull)
  programApplicationId String?
  programApplication   ProgramApplication?       @relation(fields: [programApplicationId], references: [id], onDelete: SetNull)
  outcome              String?
  statusHistory        Json                      @default("[]")
  submittedAt          DateTime                  @default(now())
  closedAt             DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([userId, status, createdAt])
  @@index([studentApplicationId])
  @@index([programApplicationId])
}

model GrantLedger {
  id             String              @id @default(cuid())
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           GrantLedgerType
  amountCents    Int
  description    String
  courseId       String?
  fundingTermId  String?
  fundingTerm    StudentFundingTerm? @relation(fields: [fundingTermId], references: [id], onDelete: SetNull)
  idempotencyKey String?             @unique
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now())

  @@index([userId, createdAt])
}

model CourseEnrollment {
  id                       String            @id @default(cuid())
  courseId                 String
  course                   Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId                   String
  user                     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                   EnrollmentStatus  @default(ACTIVE)
  progress                 Int               @default(0)
  enrolledAt               DateTime          @default(now())
  completedAt              DateTime?
  withdrawnAt              DateTime?
  withdrawalReason         String?
  refundCents              Int               @default(0)
  refundPercent            Int?
  withdrawalPenaltyBps     Int               @default(0)
  withdrawalPolicyId       String?
  withdrawalPolicy         WithdrawalPolicy? @relation(fields: [withdrawalPolicyId], references: [id], onDelete: SetNull)
  withdrawalPolicySnapshot Json?

  @@unique([courseId, userId])
  @@index([userId, status])
}

model WithdrawalPolicy {
  id            String             @id @default(cuid())
  name          String
  effectiveFrom DateTime           @unique
  timeTiers     Json
  progressTiers Json
  penaltyTiers  Json
  createdById   String?
  createdBy     User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  enrollments   CourseEnrollment[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([effectiveFrom])
}

model Guide {
  id        String        @id @default(cuid())
  slug      String        @unique
  audience  GuideAudience
  title     String
  summary   String
  category  String
  route     String?
  sortOrder Int           @default(0)
  published Boolean       @default(true)
  steps     GuideStep[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([audience, published, sortOrder])
}

model GuideStep {
  id          String          @id @default(cuid())
  guideId     String
  guide       Guide           @relation(fields: [guideId], references: [id], onDelete: Cascade)
  stepNumber  Int
  title       String
  instruction String
  controlId   String?
  progress    GuideProgress[]

  @@unique([guideId, stepNumber])
}

model GuideProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guideStepId String
  guideStep   GuideStep @relation(fields: [guideStepId], references: [id], onDelete: Cascade)
  completedAt DateTime  @default(now())

  @@unique([userId, guideStepId])
  @@index([userId, completedAt])
}

model StudentFundingStanding {
  id                         String                @id @default(cuid())
  userId                     String                @unique
  user                       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  finalizedGradeCount        Int                   @default(0)
  gradeAverage               Float                 @default(0)
  withdrawalCount            Int                   @default(0)
  withdrawalPenaltyBps       Int                   @default(0)
  gradePenaltyBps            Int                   @default(0)
  renewalMultiplierBps       Int                   @default(10000)
  status                     FundingStandingStatus @default(GOOD)
  academicHold               Boolean               @default(false)
  lastGradeAt                DateTime?
  ownerOverrideMultiplierBps Int?
  ownerOverrideReason        String?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  @@index([status, academicHold])
}

model CourseSubmission {
  id                String             @id @default(cuid())
  courseId          String
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId         String
  student           User               @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  title             String
  summary           String
  referenceUrl      String?
  demoUrl           String?
  status            SubmissionStatus   @default(SUBMITTED)
  reviewerId        String?
  reviewer          User?              @relation("SubmissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  feedback          String?
  submittedAt       DateTime           @default(now())
  reviewedAt        DateTime?
  updatedAt         DateTime           @updatedAt
  certificate       Certificate?
  aiJobs            AiGradeJob[]
  aiDecisions       AiGradeDecision[]
  appeals           SubmissionAppeal[]
  resubmissionCount Int                @default(0)

  @@unique([courseId, studentId])
  @@index([status, submittedAt])
  @@index([studentId])
}

model Certificate {
  id              String           @id @default(cuid())
  credentialCode  String           @unique
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Restrict)
  submissionId    String           @unique
  submission      CourseSubmission @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  title           String
  issuer          String
  learningCredits Int
  issuedAt        DateTime         @default(now())

  @@index([userId, issuedAt])
}

model AcademicProgram {
  id                    String                     @id @default(cuid())
  code                  String                     @unique
  title                 String
  summary               String
  level                 ProgramLevel
  creditsRequired       Int
  academy               String                     @default("Interdisciplinary Studies")
  durationDays          Int                        @default(120)
  estimatedValueCents   Int                        @default(0)
  credentialTitle       String                     @default("Program Completion Credential")
  audience              String                     @default("")
  culminatingExperience String                     @default("")
  learningOutcomes      Json                       @default("[]")
  sponsoredBy           String
  active                Boolean                    @default(true)
  enrollments           ProgramEnrollment[]
  applications          ProgramApplication[]
  requirements          ProgramCourseRequirement[]
  termPlans             StudentFundingTerm[]
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
}

model ProgramEnrollment {
  id                   String              @id @default(cuid())
  programId            String
  program              AcademicProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId               String
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               EnrollmentStatus    @default(ACTIVE)
  creditsEarned        Int                 @default(0)
  enrolledAt           DateTime            @default(now())
  completedAt          DateTime?
  programApplicationId String?             @unique
  application          ProgramApplication? @relation(fields: [programApplicationId], references: [id], onDelete: SetNull)

  @@unique([programId, userId])
  @@index([userId, status])
}

model ProgramCourseRequirement {
  id         String                 @id @default(cuid())
  programId  String
  program    AcademicProgram        @relation(fields: [programId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  type       ProgramRequirementType @default(CORE)
  sequence   Int                    @default(0)
  termNumber Int                    @default(1)

  @@unique([programId, courseId])
  @@index([programId, type, sequence])
}

model ProgramApplication {
  id              String                   @id @default(cuid())
  programId       String
  program         AcademicProgram          @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId          String
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  statement       String
  weeklyHours     Int
  experience      String
  status          ProgramApplicationStatus @default(SUBMITTED)
  decisionNote    String?
  submittedAt     DateTime                 @default(now())
  decidedAt       DateTime?
  enrollment      ProgramEnrollment?
  trackingRecords ApplicationTracking[]

  @@unique([programId, userId])
  @@index([status, submittedAt])
}

model StudentFundingTerm {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId           String?
  program             AcademicProgram?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  startsAt            DateTime
  endsAt              DateTime
  status              FundingTermStatus    @default(ACTIVE)
  scheduledValueCents Int
  reserveCents        Int
  awardedCents        Int
  renewedFromId       String?
  renewedFrom         StudentFundingTerm?  @relation("FundingRenewal", fields: [renewedFromId], references: [id], onDelete: SetNull)
  renewals            StudentFundingTerm[] @relation("FundingRenewal")
  ledgerEntries       GrantLedger[]
  plannedCourses      TermPlanCourse[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([userId, startsAt])
  @@index([userId, status, endsAt])
}

model TermPlanCourse {
  id            String             @id @default(cuid())
  fundingTermId String
  fundingTerm   StudentFundingTerm @relation(fields: [fundingTermId], references: [id], onDelete: Cascade)
  courseId      String
  course        Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sequence      Int                @default(0)

  @@unique([fundingTermId, courseId])
}

model ValueRateSchedule {
  id                     String    @id @default(cuid())
  name                   String
  hourlyInstructionCents Int
  labServicesCents       Int
  aiAssessmentCents      Int
  studioServicesCents    Int
  credentialAdminCents   Int
  effectiveFrom          DateTime
  effectiveTo            DateTime?
  active                 Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([active, effectiveFrom])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  actionUrl String?
  readAt    DateTime?
  dedupeKey String           @unique
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
}

model FacultyProfile {
  id                 String                  @id @default(cuid())
  slug               String                  @unique
  userId             String?                 @unique
  linkedUser         User?                   @relation("FacultyAccount", fields: [userId], references: [id], onDelete: SetNull)
  name               String
  title              String
  initials           String
  academy             String?
  isPrimaryAdvisor   Boolean                 @default(false)
  specialty          String
  biography          String
  teachingPhilosophy String
  voice              String
  availability       String                  @default("Available through Campus Messages")
  boundaries         Json                    @default("[]")
  deliveryMode       FacultyDeliveryMode     @default(AUTOMATED)
  active             Boolean                 @default(true)
  assignments        FacultyAssignment[]
  conversations      FacultyConversation[]
  outreachEvents     FacultyOutreachEvent[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([academy, active])
  @@index([isPrimaryAdvisor, active])
}

model FacultyAssignment {
  id               String                @id @default(cuid())
  assignmentKey    String                @unique
  studentId        String
  student          User                  @relation("StudentFacultyAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  facultyProfileId String
  facultyProfile   FacultyProfile        @relation(fields: [facultyProfileId], references: [id], onDelete: Cascade)
  type             FacultyAssignmentType
  courseId         String?
  course           Course?               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  active           Boolean               @default(true)
  assignedAt       DateTime              @default(now())

  @@index([studentId, active, type])
  @@index([facultyProfileId, active])
}

model StudentSupportProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals             Json     @default("[]")
  preferences       Json     @default("{}")
  advisorSummary    String?
  quietHoursStart   Int      @default(20)
  quietHoursEnd     Int      @default(8)
  outreachEnabled   Boolean  @default(true)
  lastOutreachAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model FacultyConversation {
  id                 String                    @id @default(cuid())
  conversationKey    String                    @unique
  studentId          String
  student            User                      @relation("StudentFacultyConversations", fields: [studentId], references: [id], onDelete: Cascade)
  facultyProfileId   String
  facultyProfile     FacultyProfile            @relation(fields: [facultyProfileId], references: [id], onDelete: Cascade)
  courseId           String?
  course             Course?                   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  subject            String
  summary            String?
  muted              Boolean                   @default(false)
  escalationStatus   FacultyEscalationStatus   @default(NONE)
  lastReadByStudentAt DateTime?
  lastMessageAt      DateTime                   @default(now())
  messages           FacultyMessage[]
  replyJobs          FacultyReplyJob[]
  outreachEvents     FacultyOutreachEvent[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([studentId, lastMessageAt])
  @@index([facultyProfileId, escalationStatus])
}

model FacultyMessage {
  id             String             @id @default(cuid())
  conversationId String
  conversation   FacultyConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderRole     FacultyMessageRole
  senderUserId   String?
  senderUser     User?              @relation("FacultyMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  body           String
  readAt         DateTime?
  createdAt      DateTime           @default(now())
  triggerJobs    FacultyReplyJob[]   @relation("FacultyReplyTrigger")
  responseJob    FacultyReplyJob?    @relation("FacultyReplyResponse")
  modelAudit     FacultyModelAudit?

  @@index([conversationId, createdAt])
}

model FacultyReplyJob {
  id                String             @id @default(cuid())
  conversationId    String
  conversation      FacultyConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  triggerMessageId  String             @unique
  triggerMessage    FacultyMessage     @relation("FacultyReplyTrigger", fields: [triggerMessageId], references: [id], onDelete: Cascade)
  responseMessageId String?            @unique
  responseMessage   FacultyMessage?    @relation("FacultyReplyResponse", fields: [responseMessageId], references: [id], onDelete: SetNull)
  status            FacultyJobStatus   @default(QUEUED)
  attempt           Int                @default(0)
  maxAttempts       Int                @default(3)
  availableAt       DateTime           @default(now())
  lockedAt          DateTime?
  lastError         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status, availableAt])
}

model FacultyOutreachEvent {
  id               String              @id @default(cuid())
  studentId        String
  student          User                @relation("StudentFacultyOutreach", fields: [studentId], references: [id], onDelete: Cascade)
  facultyProfileId String
  facultyProfile   FacultyProfile      @relation(fields: [facultyProfileId], references: [id], onDelete: Cascade)
  conversationId   String?
  conversation     FacultyConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  type             FacultyOutreachType
  dedupeKey        String              @unique
  scheduledAt      DateTime            @default(now())
  sentAt           DateTime?
  detail           Json                @default("{}")
  createdAt        DateTime            @default(now())

  @@index([studentId, scheduledAt])
  @@index([sentAt, scheduledAt])
}

model FacultyModelAudit {
  id             String         @id @default(cuid())
  messageId      String         @unique
  message        FacultyMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  modelId        String
  promptVersion  String
  contextSummary Json           @default("{}")
  tokenUsage     Json           @default("{}")
  validation     Json           @default("{}")
  createdAt      DateTime       @default(now())
}

model GradingRubric {
  id            String   @id @default(cuid())
  courseId      String   @unique
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  version       Int      @default(1)
  criteria      Json
  passingScore  Int      @default(70)
  promptVersion String   @default("efu-grader-v1")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AiGradeJob {
  id             String           @id @default(cuid())
  submissionId   String
  submission     CourseSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  status         AiGradeJobStatus @default(QUEUED)
  attempt        Int              @default(0)
  maxAttempts    Int              @default(3)
  idempotencyKey String           @unique
  availableAt    DateTime         @default(now())
  lockedAt       DateTime?
  lastError      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  decision       AiGradeDecision?

  @@index([status, availableAt])
}

model AiGradeDecision {
  id               String           @id @default(cuid())
  jobId            String           @unique
  job              AiGradeJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  submissionId     String
  submission       CourseSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  modelId          String
  promptVersion    String
  rubricVersion    Int
  wikiRevisionIds  Json             @default("[]")
  structuredResult Json
  totalScore       Int
  confidence       Float
  passed           Boolean
  status           AiDecisionStatus
  tokenUsage       Json             @default("{}")
  validationResult Json             @default("{}")
  createdAt        DateTime         @default(now())

  @@index([submissionId, createdAt])
}

model SubmissionAppeal {
  id           String           @id @default(cuid())
  submissionId String
  submission   CourseSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  studentId    String
  student      User             @relation("StudentAppeals", fields: [studentId], references: [id], onDelete: Cascade)
  reason       String
  status       AppealStatus     @default(SUBMITTED)
  reviewerId   String?
  reviewer     User?            @relation("AppealReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  resolution   String?
  submittedAt  DateTime         @default(now())
  reviewedAt   DateTime?

  @@index([status, submittedAt])
  @@index([studentId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id           String             @id @default(cuid())
  code         String             @unique
  name         String
  description  String
  type         ProjectType
  status       ProjectStatus      @default(PENDING)
  progress     Int                @default(0)
  ownerId      String
  owner        User               @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  reviewedById String?
  reviewedBy   User?              @relation("ProjectReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote   String?
  reviewedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  members      Membership[]
  updates      ProjectUpdate[]
  notes        ProjectNote[]
  objectives   ProjectObjective[]
  references   ProjectReference[]

  @@index([status])
  @@index([ownerId])
}

model ProjectUpdate {
  id        String            @id @default(cuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User              @relation(fields: [authorId], references: [id], onDelete: Restrict)
  type      ProjectUpdateType @default(PROGRESS)
  title     String
  body      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  comments  ProjectComment[]

  @@index([projectId, createdAt])
}

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  title     String
  body      String
  tags      Json     @default("[]")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, pinned, updatedAt])
}

model ProjectObjective {
  id         String            @id @default(cuid())
  projectId  String
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  details    String
  status     ObjectiveStatus   @default(PLANNED)
  priority   ObjectivePriority @default(NORMAL)
  assigneeId String?
  assignee   User?             @relation("ObjectiveAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  dueDate    DateTime?
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([projectId, status, sortOrder])
}

model ProjectReference {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  url       String
  type      String   @default("REFERENCE")
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

model ProjectComment {
  id        String        @id @default(cuid())
  updateId  String
  update    ProjectUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([updateId, createdAt])
}

model Membership {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("Contributor")
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  detail    Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}
